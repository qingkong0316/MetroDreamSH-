.sheet-overlay {
  position: fixed;
  inset: 0;
  z-index: 1400;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.32s ease, visibility 0.32s ease;
}

.sheet-overlay.is-open {
  opacity: 1;
  visibility: visible;
}

.sheet-overlay--journal {
  background: rgba(61, 52, 40, 0.42);
}

.sheet-overlay--night {
  background: rgba(6, 8, 24, 0.55);
}

.sheet-panel {
  max-height: 72vh;
  display: flex;
  flex-direction: column;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.34s cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
}

.sheet-overlay.is-open .sheet-panel {
  transform: translateY(0);
}

.sheet-panel--journal {
  background: var(--bg-surface, #FFFFFF);
  box-shadow: 0 -8rpx 40rpx rgba(61, 52, 40, 0.12);
}

.sheet-panel--night {
  background: linear-gradient(180deg, #1a2248 0%, #121830 100%);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.35);
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  margin: 16rpx auto 8rpx;
  border-radius: 999rpx;
  background: rgba(139, 115, 85, 0.2);
}

.sheet-panel--night .sheet-handle {
  background: rgba(255, 255, 255, 0.18);
}

.sheet-header {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 32rpx 20rpx;
  gap: 16rpx;
}

.sheet-header-main {
  flex: 1;
  min-width: 0;
}

.sheet-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.3;
}

.sheet-panel--journal .sheet-name {
  color: var(--text-primary, #3D3428);
}

.sheet-panel--night .sheet-name {
  color: #FFF8E7;
}

.sheet-lines {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
}

.sheet-panel--journal .sheet-lines {
  color: var(--text-secondary, #8B7355);
}

.sheet-panel--night .sheet-lines {
  color: rgba(200, 210, 240, 0.65);
}

.sheet-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sheet-panel--journal .sheet-close {
  color: var(--text-muted, #B8A992);
  background: var(--bg-muted, #F3EDE4);
}

.sheet-panel--night .sheet-close {
  color: rgba(200, 210, 240, 0.7);
  background: rgba(255, 255, 255, 0.08);
}

.sheet-body {
  flex: 1;
  height: 38vh;
  min-height: 320rpx;
  max-height: 38vh;
  padding: 0 32rpx 8rpx;
  box-sizing: border-box;
}

.sheet-section {
  padding-bottom: 8rpx;
}

.sheet-section-label {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  text-transform: none;
}

.sheet-panel--journal .sheet-section-label {
  color: var(--accent, #C17F59);
}

.sheet-panel--night .sheet-section-label {
  color: #E8C878;
}

.sheet-intro {
  display: block;
  font-size: 28rpx;
  line-height: 1.65;
}

.sheet-panel--journal .sheet-intro {
  color: var(--text-primary, #3D3428);
}

.sheet-panel--night .sheet-intro {
  color: rgba(232, 236, 255, 0.88);
}

.sheet-divider {
  height: 1rpx;
  margin: 20rpx 0;
}

.sheet-panel--journal .sheet-divider {
  background: var(--border-light, rgba(139, 115, 85, 0.08));
}

.sheet-panel--night .sheet-divider {
  background: rgba(255, 255, 255, 0.1);
}

.sheet-status-checked {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.sheet-panel--journal .sheet-status-checked {
  color: var(--success, #6B9E78);
}

.sheet-panel--night .sheet-status-checked {
  color: #A8E6B4;
}

.sheet-status-time {
  display: block;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.sheet-panel--journal .sheet-status-time {
  color: var(--text-secondary, #8B7355);
}

.sheet-panel--night .sheet-status-time {
  color: rgba(200, 210, 240, 0.75);
}

.sheet-status-memo {
  display: block;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 4rpx;
}

.sheet-panel--journal .sheet-status-memo {
  color: var(--text-primary, #3D3428);
}

.sheet-panel--night .sheet-status-memo {
  color: rgba(232, 236, 255, 0.8);
}

.sheet-status-unchecked {
  display: block;
  font-size: 24rpx;
}

.sheet-panel--journal .sheet-status-unchecked {
  color: var(--text-muted, #B8A992);
}

.sheet-panel--night .sheet-status-unchecked {
  color: rgba(200, 210, 240, 0.45);
}

.sheet-footer {
  flex-shrink: 0;
  padding: 16rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sheet-action-btn {
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 16rpx;
}

.sheet-action-btn--map {
  color: #FFE9A8;
  background: rgba(255, 233, 168, 0.14);
  border: 1rpx solid rgba(255, 233, 168, 0.3);
}

.sheet-panel--journal .sheet-action-btn--map {
  color: var(--accent, #C17F59);
  background: rgba(193, 127, 89, 0.1);
  border: 1rpx solid rgba(193, 127, 89, 0.2);
}

.sheet-action-btn--checkin {
  color: #A8E6B4;
  background: rgba(107, 158, 120, 0.14);
  border: 1rpx solid rgba(107, 158, 120, 0.28);
}

.sheet-panel--journal .sheet-action-btn--checkin {
  color: var(--success, #6B9E78);
  background: rgba(107, 158, 120, 0.1);
  border: 1rpx solid rgba(107, 158, 120, 0.2);
}

.sheet-action-btn:active {
  opacity: 0.85;
}

.sheet-undo-btn {
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 16rpx;
}

.sheet-panel--journal .sheet-undo-btn {
  color: #B85A4E;
  background: rgba(184, 90, 78, 0.1);
}

.sheet-panel--night .sheet-undo-btn {
  color: #FFB4A8;
  background: rgba(255, 120, 100, 0.12);
}

.sheet-undo-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  text-align: center;
}

.sheet-panel--journal .sheet-undo-hint {
  color: var(--text-muted, #B8A992);
}

.sheet-panel--night .sheet-undo-hint {
  color: rgba(200, 210, 240, 0.4);
}

.sheet-undo-btn:active {
  opacity: 0.8;
}
