page {
  height: 100vh;
  background: #0a0e27;
  color: #E8ECFF;
}

.night-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #0a0e27;
}

.night-top-bar {
  flex-shrink: 0;
  padding: 8rpx 0 4rpx;
}

.night-count {
  display: block;
  padding: 0 24rpx 8rpx;
  font-size: 24rpx;
  color: rgba(232, 236, 255, 0.7);
}

.night-filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.night-filter-row {
  display: inline-flex;
  flex-direction: row;
  padding: 0 20rpx 8rpx;
  gap: 10rpx;
}

.night-chip {
  flex-shrink: 0;
  padding: 8rpx 22rpx;
  font-size: 22rpx;
  color: rgba(200, 210, 240, 0.65);
  background: rgba(255, 255, 255, 0.06);
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.night-chip.active {
  color: #FFE9A8;
  background: rgba(255, 233, 168, 0.12);
  border-color: rgba(255, 233, 168, 0.35);
  font-weight: 500;
}

.night-tag-scroll {
  margin-top: 2rpx;
}

.night-chip--tag {
  font-size: 21rpx;
  padding: 6rpx 18rpx;
}

.night-canvas-wrap {
  flex: 1;
  min-height: 0;
  position: relative;
}

.night-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.night-reset-btn {
  position: absolute;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: #E8ECFF;
  background: rgba(15, 21, 53, 0.75);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  backdrop-filter: blur(8px);
}

.night-reset-btn:active {
  opacity: 0.8;
}
