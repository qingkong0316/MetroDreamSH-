<view class="page">
  <!-- 顶部区域 -->
  <view class="top-section">
    <!-- 最近 3 站 -->
    <view class="nearest-row">
      <view wx:if="{{locating}}" class="nearest-placeholder">正在定位...</view>
      <view wx:elif="{{nearestStations.length === 0}}" class="nearest-placeholder">定位失败，请重新定位</view>
      <block wx:else>
        <view
          wx:for="{{nearestStations}}"
          wx:key="id"
          class="nearest-card-item">
          <text class="nearest-item-name">{{item.name}}</text>
          <text class="nearest-item-line">{{item.line}}号线</text>
          <text class="nearest-item-dist">约 {{item.distance}} 米</text>
        </view>
      </block>
    </view>

    <!-- 进度区 -->
    <view class="progress-row">
      <view class="progress-block">
        <view class="progress-info">
          <text class="progress-title">整体打卡进度</text>
          <text class="progress-num">{{globalCheckedCount}} / {{globalTotalCount}} ({{globalProgress}}%)</text>
        </view>
        <view class="progress-bar">
          <view class="progress-inner" style="width: {{globalProgress}}%"></view>
        </view>
      </view>
      <view class="progress-block">
        <view class="progress-info">
          <text class="progress-title">{{currentLine}}号线进度</text>
          <text class="progress-num">{{checkedCount}} / {{totalCount}} ({{progress}}%)</text>
        </view>
        <view class="progress-bar">
          <view class="progress-inner" style="width: {{progress}}%"></view>
        </view>
      </view>
    </view>

    <!-- 个人进度小面板 -->
    <view class="stats-row">
      <view class="stats-card">
        <text class="stats-value">{{monthCheckinCount}}</text>
        <text class="stats-label">本月打卡</text>
      </view>
      <view class="stats-card stats-card--center">
        <text class="stats-value stats-value--name">{{lastCheckinStation}}</text>
        <text class="stats-label">最近一站</text>
      </view>
      <view class="stats-card">
        <text class="stats-value">{{exploreStreakDays}}</text>
        <text class="stats-label">连续探索天</text>
      </view>
    </view>

    <view class="metro-map-trigger" bindtap="openMetroMap">
      <text class="metro-map-trigger-icon">🌃</text>
      <view class="metro-map-trigger-text">
        <text class="metro-map-trigger-title">查看星图线路</text>
        <text class="metro-map-trigger-sub">已点亮 {{globalCheckedCount}} / {{globalTotalCount}} 站</text>
      </view>
      <text class="metro-map-trigger-chevron">＞</text>
    </view>

    <!-- 打卡操作 -->
    <view class="checkin-actions">
      <button
        class="btn-checkin-nearest"
        bindtap="handleCheckIn"
        disabled="{{!canCheckIn}}">
        {{canCheckIn ? '打卡' : '请靠近站点（100米内）'}}
      </button>
      <button class="btn-refresh" bindtap="refreshNearestStation">重新定位</button>
    </view>
  </view>

  <!-- 主体：左栏线路 + 右栏站点 -->
  <view class="body-section">
    <scroll-view scroll-y="true" class="sidebar">
      <view
        wx:for="{{lineKeys}}"
        wx:key="*this"
        class="sidebar-item {{currentLine === item ? 'active' : ''}}"
        bindtap="switchLine"
        data-line="{{item}}">
        {{item}}号线
      </view>
    </scroll-view>

    <scroll-view scroll-y="true" class="main-content">
      <block wx:for="{{stations}}" wx:key="id">
        <view wx:if="{{item.checked}}" class="station-item checked-card" bindtap="onCheckedCardTap" data-id="{{item.id}}">
          <view class="checked-row">
            <text class="name-txt ellipsis">{{item.name}}</text>
            <text class="checked-tag">已打卡</text>
          </view>
          <view class="checked-row checked-row-meta">
            <view class="meta-left">
              <text class="check-time">{{item.checkTimeText}}</text>
              <text class="memo-btn" catchtap="handleMemo" data-id="{{item.id}}">备注</text>
            </view>
            <button class="btn-undo-mini" catchtap="confirmDelete" data-id="{{item.id}}">撤销</button>
          </view>
        </view>
        <view wx:else class="station-item station-item-tappable" bindtap="onStationCardTap" data-id="{{item.id}}">
          <text class="name-txt">{{item.name}}</text>
        </view>
      </block>

      <view wx:if="{{stations.length === 0}}" class="empty-tip">
        暂无站点数据
      </view>
    </scroll-view>
  </view>

  <view class="achievement-trigger" bindtap="toggleAchievementPage">
    <text class="achievement-trigger-text">成就图鉴 ({{unlockedCount}}/{{achievementTotal}})</text>
    <text class="achievement-trigger-chevron">＞</text>
  </view>

  <view
    class="achievement-overlay {{showAchievementPage ? 'is-open' : ''}}"
    wx:if="{{showAchievementPage || achievementOverlayVisible}}"
    catchtap="closeAchievementPage">
    <view class="achievement-panel" catchtap="noop">
      <view class="achievement-panel-header">
        <text class="achievement-panel-title">成就图鉴</text>
        <text class="achievement-panel-count">{{unlockedCount}} / {{achievementTotal}}</text>
        <view class="achievement-panel-close" bindtap="toggleAchievementPage">✕</view>
      </view>

      <scroll-view scroll-y class="achievement-panel-scroll" show-scrollbar="{{false}}">
        <block wx:for="{{achievementCategories}}" wx:key="id">
          <view class="achievement-category-card">
            <view
              class="achievement-category-header"
              bindtap="toggleCategory"
              data-id="{{item.id}}">
              <text class="achievement-category-title">{{item.title}}</text>
              <text class="achievement-category-meta">{{item.unlockedInSection}}/{{item.totalInSection}}</text>
              <view class="achievement-category-arrow {{item.expanded ? 'is-expanded' : ''}}"></view>
            </view>

            <view wx:if="{{item.expanded}}" class="achievement-category-body">
              <view class="achievement-grid">
                <view
                  wx:for="{{item.items}}"
                  wx:for-item="ach"
                  wx:key="id"
                  class="achievement-card {{ach.unlocked ? 'unlocked' : 'locked'}}">
                  <text class="ach-emoji">{{ach.emoji}}</text>
                  <text class="ach-name">{{ach.name}}</text>
                  <text class="ach-desc">{{ach.desc}}</text>
                  <text wx:if="{{!ach.unlocked && ach.remainingHint}}" class="ach-hint">{{ach.remainingHint}}</text>
                  <view wx:if="{{!ach.unlocked}}" class="achievement-card-mask"></view>
                </view>
              </view>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
    <view class="dev-fab" catchtap="tapDeveloperModal">🌟</view>
  </view>

  <view
    class="dev-overlay {{showDeveloperModal ? 'is-open' : ''}}"
    wx:if="{{developerOverlayVisible || showDeveloperModal}}"
    catchtap="noop">
    <view class="dev-panel" catchtap="noop">
      <view class="dev-panel-header">
        <text class="dev-panel-title">{{developerPrefaceTitle}}</text>
        <view class="dev-panel-close" bindtap="closeDeveloperModal">✕</view>
      </view>
      <scroll-view scroll-y class="dev-panel-scroll" show-scrollbar="{{false}}">
        <text class="dev-preface-text" selectable>{{developerPrefaceContent}}</text>
      </scroll-view>
    </view>
  </view>

  <!-- 打卡成功弹窗 -->
  <view
    class="checkin-success-overlay {{showCheckinSuccessModal ? 'is-open' : ''}}"
    wx:if="{{checkinSuccessOverlayVisible || showCheckinSuccessModal}}"
    catchtap="closeCheckinSuccessModal">
    <view class="checkin-success-panel checkin-success-panel--star" catchtap="noop">
      <view class="checkin-success-stars" aria-hidden="true">
        <text class="checkin-star checkin-star--1">✦</text>
        <text class="checkin-star checkin-star--2">✧</text>
        <text class="checkin-star checkin-star--3">✦</text>
      </view>
      <view class="checkin-success-header">
        <text class="checkin-success-title">打卡成功</text>
        <view class="checkin-success-close" bindtap="closeCheckinSuccessModal">✕</view>
      </view>
      <view class="checkin-success-body">
        <text class="checkin-success-emoji">✨</text>
        <text class="checkin-success-station">{{checkinSuccessStation}}</text>
        <text wx:if="{{checkinSuccessQuote}}" class="checkin-success-quote">{{checkinSuccessQuote}}</text>
        <text class="checkin-success-sub">已记录本次打卡</text>
      </view>
      <view class="checkin-success-footer">
        <view class="checkin-success-btn" bindtap="closeCheckinSuccessModal">太棒了</view>
      </view>
    </view>
  </view>

  <!-- 成就解锁弹窗 -->
  <view
    class="unlock-overlay {{showUnlockModal ? 'is-open' : ''}}"
    wx:if="{{unlockOverlayVisible || showUnlockModal}}"
    catchtap="closeAchievementUnlockModal">
    <view class="unlock-panel" catchtap="noop" wx:if="{{unlockAchievement}}">
      <view class="unlock-stars" aria-hidden="true">
        <text class="unlock-star unlock-star--1">✦</text>
        <text class="unlock-star unlock-star--2">✧</text>
      </view>
      <text class="unlock-badge">成就解锁</text>
      <text class="unlock-emoji">{{unlockAchievement.emoji}}</text>
      <text class="unlock-name">{{unlockAchievement.name}}</text>
      <text class="unlock-desc">{{unlockAchievement.desc}}</text>
      <view class="unlock-btn" bindtap="closeAchievementUnlockModal">知道了</view>
    </view>
  </view>

  <station-sheet
    visible="{{showStationSheet}}"
    theme="journal"
    station="{{stationSheetData}}"
    showUndo="{{false}}"
    showMapLink="{{true}}"
    bind:close="closeStationSheet"
    bind:viewmap="onViewMapFromSheet"
  />
</view>
